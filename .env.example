# .env.example — every runtime environment variable the container reads.
# Copy to `.env` (git-ignored) for local `docker compose up`. Fill in the
# secrets with your OWN dev/test values. NEVER commit real secrets, and NEVER
# use production credentials for local dev.
#
# On Railway these are set as service variables in the dashboard, NOT from a
# committed file.

# ── REQUIRED (boot FAILS FAST if unset) ──────────────────────────────────────

# The Discord bot token. SECRET — treat like a password.
DISCORD_BOT_TOKEN_PRODUCTION=

# Postgres DSN (asyncpg). For docker-compose this is set in the compose file
# to the bundled `db` service; override here only if pointing elsewhere.
# Example: postgresql://superbot:superbot@db:5432/superbot
DATABASE_URL=

# Which data plane this process serves: `test` or `prod`.
# Local dev must be `test`.
SB_DATA_PLANE=test

# ── OPTIONAL ─────────────────────────────────────────────────────────────────

# Presence (any value) marks the process prod-attested. Owner-set; leave unset
# for local/test.
# SB_PROD_ATTEST=

# Health server bind. Defaults: port 8080, host :: (IPv6 dual-stack).
HEALTH_PORT=8080
HEALTH_HOST=::

# Command prefix for legacy text commands. Default: !
BOT_PREFIX=!

# Test-only: sync application (slash) commands to this single guild id for fast
# iteration. Leave blank in prod (global sync).
SB_APPCMD_SYNC_GUILD_ID=

# Set to `true` for a side-effect-free boot check (python3 -m sb.app.verify_boot)
# instead of a live run.
# SB_VERIFY_BOOT=false
