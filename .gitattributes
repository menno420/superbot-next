# substrate-kit search hygiene (planted by adopt/upgrade; the kit only ever APPENDS missing entries — existing content above is host-owned)
/bootstrap.py linguist-generated=true
/.substrate/backup/** linguist-generated=true

# telemetry/model-usage.jsonl is append-only (one JSON line per session,
# deduped by session slug, order-insensitive) — concurrent appends at EOF are
# never a real conflict, so LOCAL merges/rebases auto-resolve by keeping both
# lines. NOTE: GitHub's server-side PR mergeability/merge button does NOT
# honor this (verified live 2026-07-12, scratch PR #315) — a conflicted PR
# still needs one local `git rebase origin/main` + push, which this attribute
# makes automatic. Runbook: docs/operations/telemetry-merge-conflicts.md
/telemetry/model-usage.jsonl merge=union
